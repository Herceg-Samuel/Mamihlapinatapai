---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import Navbar from '../components/ui/Navbar.astro';
import Hero from '../components/ui/Hero.astro';
import Footer from '../components/ui/Footer.astro';
import '../styles/global.css';
import '../components/narrative/styles.css';
// import BackToTopButton from '../components/ui/back-to-top'

import {formatDate} from '../lib/fns'

import Analytics from '@vercel/analytics/astro';

const essays: CollectionEntry<'essays'>[] = await getCollection('essays', (entry: CollectionEntry<'essays'>) => {
  return entry.data.draft !== true;
});

const projects: CollectionEntry<'projects'>[] = await getCollection('projects', (entry: CollectionEntry<'projects'>) => {
  return entry.data.draft !== true;
});

const notes: CollectionEntry<'notes'>[] = await getCollection('notes', (entry: CollectionEntry<'notes'>) => {
  return entry.data.draft !== true;
});

const feed = [...essays, ...projects, ...notes].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mamihlapinatapai | Lost in Translation</title>
    <Analytics />
  </head>
  <body class="bg-primary text-gray-900 max-w-screen min-h-screen antialiased selection:bg-yellow-200">
    <Navbar />
    
    <main>
      <Hero />

      <!-- The Feed -->
      <section class="max-w-3xl mx-auto px-6 py-12">
        <h2 class="text-xs font-mono uppercase tracking-widest text-gray-800 mb-8 border-b border-gray-200 pb-4">
          Recent Thoughts & Builds
        </h2>
        
        <div class="flex flex-col gap-12">
          {feed.map((item) => (
            <article class="group relative">
              
              {/* === ESSAY RENDER LOGIC === */}
              {item.collection === 'essays' && (
                <a href={`/essays/${item.id}`} class="block">
                  <div class="flex items-center gap-3 text-xs font-mono text-gray-800 mb-2">
                    <time datetime={item.data.date.toISOString()}>
                      {formatDate(item.data.date)}
                    </time>
                    <span>—</span>
                    <span class="text-orange-500 uppercase tracking-widest">{item.data.topic}</span>
                  </div>
                  <h3 class="text-3xl md:text-4xl xl:text-5xl xl:mb-4 font-mono mb-2 group-hover:text-blue-600 transition-colors">
                    {item.data.title}
                  </h3>
                  <p class="text-gray-600 leading-relaxed">
                    {item.data.description}
                  </p>
                </a>
              )}

              {/* === PROJECT RENDER LOGIC === */}
              {item.collection === 'projects' && (
                <a href={`/projects/${item.id}`} class="block">
                  <div class="flex items-center gap-3 text-xs font-mono text-gray-800 mb-2">
                    <time datetime={item.data.date.toISOString()}>
                      {formatDate(item.data.date)}
                    </time>
                    <span>—</span>
                    <span class="text-blue-500 uppercase tracking-widest">BUILD LOG</span>
                  </div>
                  <h3 class="text-3xl md:text-4xl xl:text-5xl font-mono mb-2 group-hover:text-blue-600 transition-colors">
                    {item.data.title}
                  </h3>
                  <p class="text-gray-600 leading-relaxed mb-4">
                    {item.data.description}
                  </p>
                  
                  {/* Map through the tech stack strictly enforced by Zod */}
                  <ul class="flex flex-wrap gap-2">
                    {item.data.techStack.map((tech: string) => (
                      <li class="text-[10px] uppercase tracking-wider font-mono bg-gray-100 text-gray-500 px-2 py-1 rounded-sm">
                        {tech}
                      </li>
                    ))}
                  </ul>
                </a>
              )}

               {/* === NOTE RENDER LOGIC === */}
              {item.collection === 'notes' && (
                <a href={`/notes/${item.id}`} class="block">
                  <div class="flex items-center gap-3 text-xs font-mono text-gray-800 mb-2">
                    <time datetime={item.data.date.toISOString()}>
                      {formatDate(item.data.date)}
                    </time>
                    <span>—</span>
                    <span class="text-green-500 uppercase tracking-widest">{item.data.topic}</span>
                  </div>
                  <h3 class="text-3xl md:text-4xl xl:text-5xl xl:mb-4 font-mono mb-2 group-hover:text-blue-600 transition-colors">
                    {item.data.title}
                  </h3>
                  <p class="text-gray-600 leading-relaxed">
                    {item.data.description}
                  </p>
                </a>
              )}

            </article>
          ))}
        </div>
      </section>
    </main>
    <!-- <BackToTopButton /> -->

    <Footer />
  </body>
</html>