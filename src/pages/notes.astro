---
// src/pages/notes.astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import '../styles/global.css';
import PageLayout from '@/layouts/PageLayout.astro';

import {formatDate} from '../lib/fns'

const notes: CollectionEntry<'notes'>[] = await getCollection('notes', (entry) => {
  return entry.data.draft !== true;
});

const sortedEssays = notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()); 
---

<PageLayout title="Notes" name="All Notes">
        {sortedEssays.map((note) => (
          <a href={`/notes/${note.id}`} class="group block border-b border-gray-200 pb-8 last:border-0">
              <div class="flex items-center gap-3 text-xs font-mono text-gray-400 mb-2">
                    <time datetime={note.data.date.toISOString()}>
                      {formatDate(note.data.date)}
                    </time>
                    <span>—</span>
                    <span class="text-green-500 uppercase tracking-widest">{note.data.topic}</span>
                  </div>
            <h2 class="text-2xl font-mono group-hover:text-blue-600 transition-colors">{note.data.title}</h2>
            <p class="text-gray-600 mt-2">{note.data.description}</p>
          </a>
        ))}
</PageLayout>