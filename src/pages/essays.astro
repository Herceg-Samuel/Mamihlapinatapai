---
// src/pages/essays.astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import '../styles/global.css';
import PageLayout from '@/layouts/PageLayout.astro';

import {formatDate} from '../lib/fns'

const essays: CollectionEntry<'essays'>[] = await getCollection('essays', (entry) => {
  return entry.data.draft !== true;
});

const sortedEssays = essays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()); 
---

<PageLayout title="Essays" name="All Essays">
        {sortedEssays.map((essay) => (
          <a href={`/essays/${essay.id}`} class="group block border-b border-gray-200 pb-8 last:border-0">
              <div class="flex items-center gap-3 text-xs font-mono text-gray-400 mb-2">
                    <time datetime={essay.data.date.toISOString()}>
                      {formatDate(essay.data.date)}
                    </time>
                    <span>—</span>
                    <span class="text-red-500 uppercase tracking-widest">{essay.data.topic}</span>
                  </div>
            <h2 class="text-2xl font-mono group-hover:text-blue-600 transition-colors">{essay.data.title}</h2>
            <p class="text-gray-600 mt-2">{essay.data.description}</p>
          </a>
        ))}
</PageLayout>